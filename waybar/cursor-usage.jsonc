{
  "//_comment": "HyDE-style JSON modules often use format \"{0}\" — this binary sets \"0\" and \"text\" to the same label string.",
  "modules-right": ["custom/cursor_usage"],
  "custom/cursor_usage": {
    "return-type": "json",
    "exec": "/bin/sh -c 'exec env CURSOR_READ_SQLITE=1 /home/USER/.local/bin/cursor-waybar-usage'",
    "interval": 180,
    "format": "{0}",
    "tooltip": true,
    "tooltip-format": "{tooltip}",
    "rotate": 0,
    "max-length": 48
  }
}
