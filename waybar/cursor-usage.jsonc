{
  "//_comment": "Merge custom module into your bar; paths may need adjusting.",
  "modules-right": ["custom/cursor_usage"],
  "custom/cursor_usage": {
    "return-type": "json",
    "exec": "/home/USER/.local/bin/cursor-waybar-usage",
    "interval": 180,
    "format": "{text}",
    "tooltip-format": "{tooltip}"
  }
}
