{
  "//_1": "HyDE: use layout hyprdots/05-cursor or add group/pill#cursor + custom/cursor_usage to modules-left.",
  "//_2": "This file only defines the module; layout lists place it on the bar.",
  "custom/cursor_usage": {
    "return-type": "json",
    "exec": "/bin/sh -c 'exec \"$HOME/.local/bin/cursor-waybar-usage\"'",
    "interval": 120,
    "format": "{0}",
    "tooltip": true,
    "tooltip-format": "{tooltip}",
    "rotate": 0,
    "max-length": 28
  }
}
