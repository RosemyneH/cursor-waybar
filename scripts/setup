#!/usr/bin/env bash
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$HERE/.." && pwd)"
cd "$ROOT"

usage() {
	printf '%s\n' "Usage: $0 [--no-token] [hyde]" >&2
	printf '%s\n' "  (default)  build, install, Waybar modules + HyDE layout hyprdots/05-cursor, token setup" >&2
	printf '%s\n' "  --no-token same but skip cursor-waybar-setup" >&2
	printf '%s\n' "  hyde       print HyDE picker hint; optional: --no-token" >&2
	exit 1
}

NO_TOKEN=0
MODE=""
for a in "$@"; do
	case "$a" in
	--no-token) NO_TOKEN=1 ;;
	-h | --help) usage ;;
	hyde) MODE=hyde ;;
	*) usage ;;
	esac
done

if [[ "$MODE" == "hyde" ]]; then
	printf '%s\n' "HyDE: in Waybar layout / wbar config, select layout hyprdots/05-cursor (installed under \$XDG_DATA_HOME/waybar/layouts/hyprdots/ by setup-waybar-snippets)."
fi

make
make install

bash "$HERE/setup-waybar-snippets"

if [[ "$NO_TOKEN" == 0 ]]; then
	if command -v cursor-waybar-setup >/dev/null 2>&1; then
		cursor-waybar-setup
	else
		bash "$HERE/cursor-waybar-setup"
	fi
fi

printf '\n%s\n' 'Reload Waybar. Mock check: CURSOR_WAYBAR_MOCK_JSON='"'"'{"text":"Cur 0%","tooltip":"ok","percentage":0}'"'"' cursor-waybar-usage'
