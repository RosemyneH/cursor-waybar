#!/usr/bin/env bash
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$HERE/.." && pwd)"
cd "$ROOT"

usage() {
	printf '%s\n' "Usage: $0 [--no-token] [hyde]" >&2
	printf '%s\n' "  (default)  build, install, install Waybar snippets under ~/.config/waybar/modules/, run token setup" >&2
	printf '%s\n' "  --no-token same but skip cursor-waybar-setup" >&2
	printf '%s\n' "  hyde       print HyDE layout hints; optional: --no-token" >&2
	exit 1
}

NO_TOKEN=0
MODE=""
for a in "$@"; do
	case "$a" in
	--no-token) NO_TOKEN=1 ;;
	-h | --help) usage ;;
	hyde) MODE=hyde ;;
	*) usage ;;
	esac
done

if [[ "$MODE" == "hyde" ]]; then
	printf '%s\n' "HyDE: put the JSONC from this repo’s waybar/ next to your other Waybar modules, and add"
	printf '%s\n' "  custom/cursor_usage  and  image#cursor_brand"
	printf '%s\n' "to your layout group (e.g. pill#cursor modules). Hyde regens can drop custom names — re-add after regen."
	printf '%s\n' "Paths in upstream HyDE trees often mirror: .local/share/waybar/modules/ and layouts/hyprdots/."
fi

make
make install

if [[ "$MODE" != "hyde" ]]; then
	bash "$HERE/setup-waybar-snippets"
fi

if [[ "$NO_TOKEN" == 0 ]]; then
	if command -v cursor-waybar-setup >/dev/null 2>&1; then
		cursor-waybar-setup
	else
		bash "$HERE/cursor-waybar-setup"
	fi
fi

printf '\nReload Waybar. Mock check: CURSOR_WAYBAR_MOCK_JSON='"'"'{"text":"Cur 0%","tooltip":"ok","percentage":0}'"'"' cursor-waybar-usage\n'
